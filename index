<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Haus of Bakeries</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #fff7f0;
        }

        header {
            background-color: #8b4513;
            color: white;
            text-align: center;
            padding: 20px;
        }

        nav {
            background-color: #d2691e;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
        }

        h2 {
            text-align: center;
            color: #8b4513;
            margin-top: 30px;
        }

        .products {
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap;
            padding: 20px;
        }

        .card {
            background: white;
            width: 260px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            overflow: hidden;
            text-align: center;
        }

        .card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }

        .card h3 {
            color: #8b4513;
            margin: 10px 0;
        }

        .price {
            color: #d2691e;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .btn {
            display: inline-block;
            background-color: #8b4513;
            color: white;
            padding: 10px 15px;
            margin-bottom: 15px;
            border-radius: 5px;
            text-decoration: none;
        }

        .btn:hover {
            background-color: #5a2d0c;
        }

        footer {
            background-color: #8b4513;
            color: white;
            text-align: center;
            padding: 10px;
            margin-top: 30px;
        }
    </style>
</head>

<body>

<header>
    <h1>Haus of Bakeries</h1>
    <p>Fresh • Handmade • Delicious</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Menu</a>
    <a href="#">Contact</a>
</nav>

<h2>Our Bakery Items</h2>

<div class="products">

    <div class="card">
        <img src="cake.jpg" alt="Chocolate Cake">
        <h3>Chocolate Cake</h3>
        <p class="price">Rs. 1200</p>
        <a href="#" class="btn">Add to Cart</a>
    </div>

    <div class="card">
        <img src="bread.jpg" alt="Fresh Bread">
        <h3>Fresh Bread</h3>
        <p class="price">Rs. 150</p>
        <a href="#" class="btn">Add to Cart</a>
    </div>

    <div class="card">
        <img src="cupcake.jpg" alt="Cupcake">
        <h3>Cupcake</h3>
        <p class="price">Rs. 80</p>
        <a href="#" class="btn">Add to Cart</a>
    </div>

</div>

<footer>
    <p>© 2026 Haus of Bakeries | All Rights Reserved</p>
</footer>

</body>
</html>
